<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="inquiryMapper">

    <select id="selectInquiryListCount" resultType="_int">
        SELECT COUNT(*)
          FROM INQUIRY
    </select>

    <select id="selectInquiryList" resultType="Inquiry">
        SELECT
               INQUIRY_ID,
               MEMBER_NO,
               INQUIRY_TYPE,
               INQUIRY_CONTENT,
               INQUIRY_PHOTO,
               INQUIRY_PW,
               INQUIRY_REG_DATE,
               REPLY_CONTENT,
               REPLY_DATE,
               REPLY_YN
          FROM INQUIRY
         ORDER BY INQUIRY_ID DESC
    </select>

</mapper>