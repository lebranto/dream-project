<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="adminMember">

	<!-- resultMap -->
    <!--
        Member.java 필드명 기준:
        address   ← MEMBER_ADDRESS
        joinDate  ← MEMBER_JOIN_DATE (Date 타입)
        activeYn  ← MEMBER_ACTIVE_YN
    -->
    <resultMap id="memberRM" type="Member">
        <id     property="memberNo"   column="MEMBER_NO"/>
        <result property="memberId"   column="MEMBER_ID"/>
        <result property="memberName" column="MEMBER_NAME"/>
        <result property="address"    column="MEMBER_ADDRESS"/>
        <result property="phone"      column="PHONE"/>
        <result property="email"      column="EMAIL"/>
        <result property="joinDate"   column="MEMBER_JOIN_DATE"/>
        <result property="activeYn"   column="MEMBER_ACTIVE_YN"/>
    </resultMap>
 
    <sql id="searchWhere">
        <where>
            <if test="startDate != null and startDate != ''">
                AND M.MEMBER_JOIN_DATE &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>
            <if test="endDate != null and endDate != ''">
                AND M.MEMBER_JOIN_DATE &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
            <if test="memberStatus != null and memberStatus != ''">
                AND M.MEMBER_ACTIVE_YN = #{memberStatus}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    M.MEMBER_NAME LIKE '%' || #{keyword} || '%'
                 OR M.MEMBER_ID   LIKE '%' || #{keyword} || '%'
                 OR M.EMAIL       LIKE '%' || #{keyword} || '%'
                 OR M.PHONE       LIKE '%' || #{keyword} || '%'
                )
            </if>
        </where>
    </sql>
	
	<!-- 통계 -->
    <select id="getActiveCount" resultType="int">
        SELECT COUNT(*) 
        FROM MEMBER 
        WHERE MEMBER_ACTIVE_YN = 'Y'
    </select>
 
    <select id="getBannedCount" resultType="int">
        SELECT COUNT(*) 
        FROM MEMBER 
        WHERE MEMBER_ACTIVE_YN = 'N'
    </select>
 
    <!-- 전체 수 -->
    <select id="getMemberCount" parameterType="map" resultType="int">
        SELECT COUNT(*)
        FROM MEMBER M
        <include refid="searchWhere"/>
    </select>
 
    <!-- 목록 (페이징) -->
    <select id="getMemberList" parameterType="map" resultMap="memberRM">
        SELECT *
        FROM (
            SELECT ROWNUM AS RNUM, T.*
            FROM (
                SELECT
                    M.MEMBER_NO,
                    M.MEMBER_ID,
                    M.MEMBER_NAME,
                    M.MEMBER_ADDRESS,
                    M.PHONE,
                    M.EMAIL,
                    M.MEMBER_JOIN_DATE,
                    M.MEMBER_ACTIVE_YN
                FROM MEMBER M
                <include refid="searchWhere"/>
                ORDER BY M.MEMBER_JOIN_DATE DESC
            ) T
            WHERE ROWNUM &lt;= #{pi.boardLimit} * #{pi.currentPage}
        )
        WHERE RNUM &gt; #{pi.boardLimit} * (#{pi.currentPage} - 1)
    </select>
	
	<!-- 상세 조회 -->
    <select id="getMemberByNo" parameterType="int" resultMap="memberRM">
        SELECT
            M.MEMBER_NO,
            M.MEMBER_ID,
            M.MEMBER_NAME,
            M.MEMBER_ADDRESS,
            M.PHONE,
            M.EMAIL,
            M.MEMBER_JOIN_DATE,
            M.MEMBER_ACTIVE_YN
        FROM MEMBER M
        WHERE M.MEMBER_NO = #{memberNo}
    </select>
	
	<!-- 정보 수정 -->
    <update id="updateMember" parameterType="Member">
        UPDATE MEMBER
        SET
            MEMBER_NAME    = #{memberName},
            MEMBER_ADDRESS = #{address},
            PHONE          = #{phone},
            EMAIL          = #{email}
        WHERE MEMBER_NO = #{memberNo}
    </update>
	
	<!-- 회원 탈퇴 -->
	<update id="updateMemberActiveYn" parameterType="int">
		UPDATE MEMBER
		SET MEMBER_ACTIVE_YN = 'N'
		WHERE MEMBER_NO = #{memberNo}
	</update>
	
	<!-- 반려동물 목록 조회 -->
    <select id="getPetListByMemberNo" parameterType="int" resultType="Pet">
        SELECT
            PET_NO      AS petNo,
            MEMBER_NO   AS memberNo,
            PET_TYPE    AS petType,
            PET_NAME    AS petName,
            PET_AGE     AS petAge,
            PET_WEIGHT  AS petWeight,
            PET_PHOTO   AS petPhoto
        FROM PET
        WHERE MEMBER_NO = #{memberNo}
    </select>
</mapper>